{
  "spacing": {
    "$type": "dimension",
    "1": { "$value": "0.25rem" },
    "2": { "$value": "0.5rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "5": { "$value": "1.25rem" },
    "6": { "$value": "1.5rem" },
    "8": { "$value": "2rem" },
    "10": { "$value": "2.5rem" },
    "12": { "$value": "3rem" },
    "16": { "$value": "4rem" },
    "20": { "$value": "5rem" },
    "24": { "$value": "6rem" }
  },
  "fontWeight": {
    "$type": "fontWeight",
    "regular": { "$value": 400 },
    "medium": { "$value": 500 },
    "semibold": { "$value": 600 },
    "bold": { "$value": 700 }
  },
  "fontSize": {
    "$type": "dimension",
    "xs": { "$value": "0.75rem" },
    "sm": { "$value": "0.875rem" },
    "base": { "$value": "1rem" },
    "lg": { "$value": "1.125rem" },
    "xl": { "$value": "1.25rem" },
    "2xl": { "$value": "1.5rem" },
    "3xl": { "$value": "1.875rem" },
    "4xl": { "$value": "2.25rem" },
    "5xl": { "$value": "3rem" },
    "display": { "$value": "3.5rem" }
  },
  "lineHeight": {
    "$type": "number",
    "tight": { "$value": 1.25 },
    "normal": { "$value": 1.5 },
    "relaxed": { "$value": 1.75 }
  },
  "letterSpacing": {
    "$type": "dimension",
    "tight": { "$value": "-0.02em" },
    "normal": { "$value": "0" },
    "wide": { "$value": "0.08em" }
  }
}
