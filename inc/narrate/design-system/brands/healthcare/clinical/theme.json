{
  "$description": "Clinical theme — sterile, precise, institutional medical",
  "color": {
    "$type": "color",
    "primary": { "$value": "{brand.primary}" },
    "primary-hover": { "$value": "{brand.primary-dark}" },
    "secondary": { "$value": "{brand.secondary}" },
    "secondary-hover": { "$value": "{brand.secondary-dark}" },
    "accent": { "$value": "#2563eb", "$description": "Blue — links, actions, alerts" },
    "error": { "$value": "#dc2626" },
    "warning": { "$value": "#d97706" },
    "success": { "$value": "#16a34a" },
    "info": { "$value": "#0284c7" }
  },
  "borderRadius": {
    "$type": "dimension",
    "sm": { "$value": "0.375rem" },
    "md": { "$value": "0.5rem" },
    "lg": { "$value": "0.75rem" },
    "xl": { "$value": "1rem" }
  }
}
