{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "$type": "color",
    "primary": {
      "$value": "#2563eb",
      "$description": "Primary brand colour"
    },
    "primary-dark": {
      "$value": "#1e40af",
      "$description": "Primary dark variant (hover states)"
    },
    "primary-light": {
      "$value": "#3b82f6",
      "$description": "Primary light variant"
    },
    "secondary": {
      "$value": "#8b5cf6",
      "$description": "Secondary brand colour"
    },
    "accent": {
      "$value": "#06b6d4",
      "$description": "Accent colour (cyan)"
    },
    "text": {
      "primary": {
        "$value": "#0f172a",
        "$description": "Primary text colour"
      },
      "secondary": {
        "$value": "#475569",
        "$description": "Secondary text colour"
      },
      "tertiary": {
        "$value": "#64748b",
        "$description": "Tertiary/muted text colour"
      },
      "inverse": {
        "$value": "#ffffff",
        "$description": "Text on dark backgrounds"
      }
    },
    "bg": {
      "primary": {
        "$value": "#ffffff",
        "$description": "Primary background"
      },
      "secondary": {
        "$value": "#f8fafc",
        "$description": "Secondary/subtle background"
      },
      "tertiary": {
        "$value": "#f1f5f9",
        "$description": "Tertiary background"
      },
      "dark": {
        "$value": "#0f172a",
        "$description": "Dark section background"
      }
    },
    "border": {
      "default": {
        "$value": "#e2e8f0",
        "$description": "Default border colour"
      },
      "dark": {
        "$value": "#cbd5e1",
        "$description": "Darker border variant"
      }
    },
    "success": {
      "$value": "#059669",
      "$description": "Success state colour"
    },
    "warning": {
      "$value": "#d97706",
      "$description": "Warning state colour"
    },
    "error": {
      "$value": "#dc2626",
      "$description": "Error state colour"
    }
  },
  "spacing": {
    "$type": "dimension",
    "1": { "$value": "0.25rem", "$description": "4px" },
    "2": { "$value": "0.5rem", "$description": "8px" },
    "3": { "$value": "0.75rem", "$description": "12px" },
    "4": { "$value": "1rem", "$description": "16px" },
    "5": { "$value": "1.25rem", "$description": "20px" },
    "6": { "$value": "1.5rem", "$description": "24px" },
    "8": { "$value": "2rem", "$description": "32px" },
    "10": { "$value": "2.5rem", "$description": "40px" },
    "12": { "$value": "3rem", "$description": "48px" },
    "16": { "$value": "4rem", "$description": "64px" },
    "20": { "$value": "5rem", "$description": "80px" },
    "24": { "$value": "6rem", "$description": "96px" }
  },
  "borderRadius": {
    "$type": "dimension",
    "sm": { "$value": "0.25rem", "$description": "4px" },
    "md": { "$value": "0.375rem", "$description": "6px" },
    "lg": { "$value": "0.5rem", "$description": "8px" },
    "xl": { "$value": "0.75rem", "$description": "12px" },
    "2xl": { "$value": "1rem", "$description": "16px" },
    "full": { "$value": "9999px", "$description": "Fully rounded" }
  },
  "shadow": {
    "$type": "shadow",
    "sm": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0px",
        "color": "#0000000d"
      }
    },
    "md": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "4px",
        "blur": "6px",
        "spread": "-1px",
        "color": "#0000001a"
      }
    },
    "lg": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "10px",
        "blur": "15px",
        "spread": "-3px",
        "color": "#0000001a"
      }
    },
    "xl": {
      "$value": {
        "offsetX": "0px",
        "offsetY": "20px",
        "blur": "25px",
        "spread": "-5px",
        "color": "#0000001a"
      }
    }
  },
  "fontFamily": {
    "$type": "fontFamily",
    "primary": {
      "$value": ["-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "Oxygen", "Ubuntu", "Cantarell", "sans-serif"],
      "$description": "System font stack"
    },
    "mono": {
      "$value": ["SF Mono", "Monaco", "Inconsolata", "Fira Code", "Consolas", "monospace"],
      "$description": "Monospace font stack"
    }
  },
  "fontSize": {
    "$type": "dimension",
    "xs": { "$value": "0.75rem" },
    "sm": { "$value": "0.875rem" },
    "base": { "$value": "1rem" },
    "lg": { "$value": "1.125rem" },
    "xl": { "$value": "1.25rem" },
    "2xl": { "$value": "1.5rem" },
    "3xl": { "$value": "1.875rem" },
    "4xl": { "$value": "2.25rem" },
    "5xl": { "$value": "3rem" },
    "6xl": { "$value": "3.75rem" }
  },
  "fontWeight": {
    "$type": "fontWeight",
    "normal": { "$value": 400 },
    "medium": { "$value": 500 },
    "semibold": { "$value": 600 },
    "bold": { "$value": 700 }
  },
  "lineHeight": {
    "$type": "number",
    "tight": { "$value": 1.25 },
    "normal": { "$value": 1.5 },
    "relaxed": { "$value": 1.75 }
  },
  "transition": {
    "$type": "duration",
    "fast": { "$value": "150ms" },
    "base": { "$value": "300ms" },
    "slow": { "$value": "500ms" }
  }
}
