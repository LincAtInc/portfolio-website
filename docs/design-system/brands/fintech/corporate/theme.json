{
  "$description": "Corporate theme — conservative, institutional, Bloomberg-grade",
  "color": {
    "$type": "color",
    "primary": { "$value": "{brand.primary}" },
    "primary-hover": { "$value": "{brand.primary-dark}" },
    "secondary": { "$value": "{brand.secondary}" },
    "secondary-hover": { "$value": "{brand.secondary-dark}" },
    "accent": { "$value": "#0f766e", "$description": "Teal — positive growth, success" },
    "error": { "$value": "#dc2626", "$description": "Loss / negative" },
    "warning": { "$value": "#d97706" },
    "success": { "$value": "#16a34a", "$description": "Gain / positive" },
    "info": { "$value": "#2563eb" }
  },
  "borderRadius": {
    "$type": "dimension",
    "$description": "Sharp — conservative, precise, institutional",
    "sm": { "$value": "0.125rem" },
    "md": { "$value": "0.25rem" },
    "lg": { "$value": "0.375rem" },
    "xl": { "$value": "0.5rem" }
  }
}
