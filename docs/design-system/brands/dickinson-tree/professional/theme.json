{
  "$description": "Professional theme — clean, trustworthy modern trade business",
  "color": {
    "$type": "color",
    "primary": { "$value": "{brand.primary}" },
    "primary-hover": { "$value": "{brand.primary-dark}" },
    "secondary": { "$value": "{brand.secondary}" },
    "secondary-hover": { "$value": "#92400e" },
    "accent": { "$value": "{brand.accent}" },
    "error": { "$value": "#dc2626" },
    "success": { "$value": "#16a34a" }
  },
  "borderRadius": {
    "$type": "dimension",
    "sm": { "$value": "0.25rem" },
    "md": { "$value": "0.375rem" },
    "lg": { "$value": "0.5rem" },
    "xl": { "$value": "0.75rem" }
  }
}
